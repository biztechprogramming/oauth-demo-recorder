# Required: OpenAI key for TTS narration.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required for YouTube upload. Create an OAuth 2.0 client of type
# "Desktop app" in any GCP project (it's just for authenticating you as
# the channel owner). See README.md → "First-time YouTube setup".
YOUTUBE_CLIENT_ID=...apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...

# Optional: override the TTS model and voice.
# Models: tts-1 (faster, cheaper) or tts-1-hd (higher quality).
# Voices: alloy, ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer, verse.
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=onyx
